node_modules/

# Build artifacts — generated by `npm run build`, shipped to npm via
# the `files` field but never committed.
spektrum.min.js
companions/*.min.js

# Generated TypeDoc HTML — built by `npm run docs` and deployed to
# GitHub Pages via .github/workflows/docs.yml. Never committed.
docs-site/

# Working notes / drafts that live outside the published docs.
# The folder's purpose is documented in notes/README.md (tracked); the
# rest of the folder is contributor-local scratch space.
notes/*
!notes/README.md

# Misc
*.tgz
.DS_Store

# CLAUDE
# Settings file is per-machine; .claude/skills/ is tracked so
# consumers' Claude Code sessions auto-load the Spektrum skill.
.claude/settings.local.json
